/*
 * secrets.h.example — template for your TTN ABP session keys.
 *
 * Copy this file to secrets.h and fill in the three values from the TTN
 * console (your application -> your end device -> activation information).
 * secrets.h is gitignored; never commit real keys.
 *
 * BYTE ORDER — read this carefully, it is the #1 bug (Lecture 2):
 *   - The TTN console shows DevAddr big-endian (MSB first), e.g. 26011F88.
 *     On the wire LoRaWAN needs it little-endian, so byte-REVERSE it:
 *     26 01 1F 88  ->  { 0x88, 0x1F, 0x01, 0x26 }
 *   - NwkSKey and AppSKey are used as 16-byte AES keys in the order the
 *     console prints them (MSB first) — do NOT reverse these.
 */

#ifndef CC_SECRETS_H_
#define CC_SECRETS_H_

/* DevAddr, LITTLE-ENDIAN (reversed from the console display). */
#define SECRET_DEVADDR_LE   { 0x88, 0x1F, 0x01, 0x26 }   /* console: 26011F88 */

/* NwkSKey, 16 bytes, in console order (NOT reversed). */
#define SECRET_NWKSKEY      { \
    0x2B,0x7E,0x15,0x16,0x28,0xAE,0xD2,0xA6, \
    0xAB,0xF7,0x15,0x88,0x09,0xCF,0x4F,0x3C  }

/* AppSKey, 16 bytes, in console order (NOT reversed). */
#define SECRET_APPSKEY      { \
    0x00,0x11,0x22,0x33,0x44,0x55,0x66,0x77, \
    0x88,0x99,0xAA,0xBB,0xCC,0xDD,0xEE,0xFF  }

#endif /* CC_SECRETS_H_ */
